@model List<OtelManagerDpr.Models.RezervasyonModel>
@{
    ViewData["Title"] = "Rezervasyonlar";
}

<h2>Rezervasyonlar</h2>
<a asp-action="EY" class="btn btn-success mb-3">+ Yeni Rezervasyon Ekle</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Rezervasyon No</th>
            <th>Müşteri</th>
            <th>Oda</th>
            <th>Giriş Tarihi</th>
            <th>Çıkış Tarihi</th>
            <th>Toplam Tutar</th>
            <th>Durum</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RezervasyonNo</td>
                <td>@item.MusteriAdSoyad</td>
                <td>@item.OdaKodu</td>
                <td>@item.GirisTarihi.ToString("dd.MM.yyyy")</td>
                <td>@item.CikisTarihi.ToString("dd.MM.yyyy")</td>
                <td>@item.ToplamTutar ₺</td>
                <td>@item.Durum</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.RezervasyonNo" asp-route-odaNo="@item.OdaNo"
                       class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>