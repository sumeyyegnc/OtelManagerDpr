@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- Masthead-->
<header class="masthead" style="background-image: url('/assets/img/otel.png');">
    <div class="container px-4 px-lg-5 d-flex h-100 align-items-center justify-content-center">
        <div class="d-flex justify-content-center">
            <div class="text-center">
                <h1 class="mx-auto my-0 text-uppercase">Otel Manager</h1>
                <h2 class="text-white-50 mx-auto mt-2 mb-5">Hayalinizdeki tatil, tek tıkla başlar. Hızlı ve kolay oda rezervasyonu.</h2>
                <a class="btn btn-primary" href="#hakkimizda">Rezervasyon Yap</a>
            </div>
        </div>
    </div>
</header>

<!-- About-->
<section class="about-section text-center" id="hakkimizda">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-lg-8">
                <h2 class="text-white mb-4">Konforlu Bir Konaklama Deneyimi</h2>
                <p class="text-white-50">
                    Otel Manager ile odanızı saniyeler içinde rezerve edin, konaklama sürenizi
                    ve oda tercihinizi kolayca yönetin. Standart, Deluxe ve Suit seçenekleriyle
                    her bütçeye uygun bir oda sizi bekliyor.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Odalar -->
<section class="projects-section bg-light" id="odalar">
    <div class="container px-4 px-lg-5">
        <!-- Öne Çıkan Oda -->
        <div class="row gx-0 mb-4 mb-lg-5 align-items-center">
            <div class="col-xl-8 col-lg-7"><img class="img-fluid mb-3 mb-lg-0" src="/assets/img/drink.png" alt="Deniz manzaralı oda" /></div>
            <div class="col-xl-4 col-lg-5">
                <div class="featured-text text-center text-lg-left">
                    <h4>Deniz Manzaralı Suit</h4>
                    <p class="text-black-50 mb-0">Eşsiz deniz manzarası eşliğinde unutulmaz bir konaklama deneyimi. Geniş balkon ve özel jakuzi imkanı.</p>
                </div>
            </div>
        </div>
        <!-- Oda Tipi Bir -->
        <div class="row gx-0 mb-5 mb-lg-0 justify-content-center">
            <div class="col-lg-6"><img class="img-fluid" src="/assets/img/deniz.png" alt="Standart oda" /></div>
            <div class="col-lg-6">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-left">
                            <h4 class="text-white">Standart Oda</h4>
                            <p class="mb-0 text-white-50">Ekonomik ve konforlu, kısa konaklamalar için ideal oda seçeneği.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Oda Tipi İki -->
        <div class="row gx-0 justify-content-center">
            <div class="col-lg-6"><img class="img-fluid" src="/assets/img/oda.png" alt="Deluxe oda" /></div>
            <div class="col-lg-6 order-lg-first">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-right">
                            <h4 class="text-white">Deluxe Oda</h4>
                            <p class="mb-0 text-white-50">Geniş yaşam alanı ve premium konfor ile ailenizle huzurlu bir tatil.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Rezervasyon Bilgilendirme -->
<section class="signup-section" id="bilgi">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5">
            <div class="col-md-10 col-lg-8 mx-auto text-center">
                <i class="far fa-calendar-check fa-2x mb-2 text-white"></i>
                <h2 class="text-white mb-4">Rezervasyon Yapmak Çok Kolay</h2>
                <p class="text-white-50 mb-4">
                    Menüden "Rezervasyonlar" sekmesine giderek müsait odalarımızı görebilir,
                    giriş-çıkış tarihlerinizi seçip anında rezervasyonunuzu oluşturabilirsiniz.
                </p>
                <a class="btn btn-primary" asp-controller="Rezervasyon" asp-action="EY">Hemen Rezervasyon Yap</a>
            </div>
        </div>
    </div>
</section>

<!-- İletişim-->
<section class="contact-section bg-black">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5">
            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-map-marked-alt text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">Adres</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">Sahil Caddesi No:1, İstanbul</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-envelope text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">E-posta</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50"><a href="mailto:info@otelmanager.com">info@otelmanager.com</a></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-mobile-alt text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">Telefon</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">+90 (212) 555 00 00</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Footer-->
<footer class="footer bg-black small text-center text-white-50">
    <div class="container px-4 px-lg-5">Copyright &copy; Otel Manager 2026</div>
</footer>