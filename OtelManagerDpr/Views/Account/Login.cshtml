@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Giriş Yap</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width:400px;">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="mb-4 text-center">Otel Manager</h3>

                @if (ViewBag.Hata != null)
                {
                    <div class="alert alert-danger">@ViewBag.Hata</div>
                }

                <form method="post" asp-action="Login">
                    <div class="mb-3">
                        <label>Kullanıcı Adı</label>
                        <input type="text" name="kullaniciAdi" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Şifre</label>
                        <input type="password" name="sifre" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
                    <a asp-action="Register" class="btn btn-link w-100 mt-2">Hesabın yok mu? Kayıt ol</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>