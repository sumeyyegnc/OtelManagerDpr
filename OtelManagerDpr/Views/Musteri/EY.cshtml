@model OtelManagerDpr.Models.MusteriModel
@{
    ViewData["Title"] = "Müşteri Ekle/Düzenle";
}

<h2>@(Model == null ? "Yeni Müşteri Ekle" : "Müşteriyi Düzenle")</h2>

<form asp-action="EY" method="post" style="max-width:500px;">
    <input type="hidden" name="MusteriNo" value="@(Model?.MusteriNo ?? 0)" />

    <div class="mb-3">
        <label>Ad Soyad</label>
        <input type="text" name="AdSoyad" class="form-control" value="@Model?.AdSoyad" required />
    </div>
    <div class="mb-3">
        <label>TC No</label>
        <input type="text" name="TcNo" class="form-control" value="@Model?.TcNo" maxlength="11" />
    </div>
    <div class="mb-3">
        <label>Telefon</label>
        <input type="text" name="Telefon" class="form-control" value="@Model?.Telefon" />
    </div>
    <div class="mb-3">
        <label>E-posta</label>
        <input type="email" name="Eposta" class="form-control" value="@Model?.Eposta" />
    </div>
    <div class="mb-3">
        <label>Adres</label>
        <textarea name="Adres" class="form-control">@Model?.Adres</textarea>
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">Vazgeç</a>
</form>