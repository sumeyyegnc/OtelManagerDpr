@model List<OtelManagerDpr.Models.MusteriModel>
@{
    ViewData["Title"] = "Müşteriler";
}

<a asp-action="ExportToPdf" class="btn btn-danger">
    PDF İndir
</a>

<a asp-action="ExportToExcel" class="btn btn-success">
    Excel İndir
</a>

<h2>Müşteriler</h2>
<a asp-action="EY" class="btn btn-success mb-3">+ Yeni Müşteri Ekle</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Müşteri No</th>
            <th>Ad Soyad</th>
            <th>TC No</th>
            <th>Telefon</th>
            <th>E-posta</th>
            <th>Adres</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MusteriNo</td>
                <td>@item.AdSoyad</td>
                <td>@item.TcNo</td>
                <td>@item.Telefon</td>
                <td>@item.Eposta</td>
                <td>@item.Adres</td>
                <td>
                    <a asp-action="EY" asp-route-id="@item.MusteriNo" class="btn btn-sm btn-primary">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.MusteriNo" class="btn btn-sm btn-danger"
                       onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>